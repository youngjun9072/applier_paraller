+	    }
+
+	  if (commit->prev)
+	    {
+	      commit->prev->next = commit->next;
+	    }
+	  else
+	    {
+	      la_Info.commit_head = commit->next;
+	    }
+
+	  commit->next = NULL;
+	  commit->prev = NULL;
