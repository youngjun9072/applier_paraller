+      if (worker->result_queue.results[idx].seq == seq)
+	{
+	  found = true;
+	  break;
+	}
+      idx = (idx + 1) % LA_APPLY_WORKER_QUEUE_CAPACITY;
+    }
+  pthread_mutex_unlock (&worker->mutex);
+
+  return found;
+}
